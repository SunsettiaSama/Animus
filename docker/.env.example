# =============================================================================
# ReAct Agent 生产环境配置
# 复制此文件为 .env 并填入实际值
# =============================================================================

# REACT_IMAGE: CI/CD publishes ghcr.io/<owner_lower>/react-agent with tags from docker/metadata-action
# Immutability: prefer pin by digest exactly as workflows pass to deploy —
#   REACT_IMAGE=ghcr.io/<owner_lower>/react-agent@sha256:<digest>
# Common tags pushed on events: semver on git tag; branch-/pr- prefixed refs;
# deterministic sha-<git_full_sha>; type=sha,format=long index on registry.
#
# Compose service name aligned with workflows: react (see docker/docker-compose.prod.yml)
REACT_IMAGE=ghcr.io/your-org/your-repo/react-agent:latest
LOG_LEVEL=INFO

# MySQL 配置
MYSQL_ROOT_PASSWORD=your-secure-password-here
MYSQL_DATABASE=knowledge

# Redis 配置
REDIS_PASSWORD=your-redis-password-here

# Grafana 配置
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-grafana-password-here

# 可选：域名配置
DOMAIN=your-domain.com

# 可选：HTTPS 证书（Let's Encrypt）
LETSENCRYPT_EMAIL=your-email@example.com
