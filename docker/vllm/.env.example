# =============================================================================
# docker/vllm/.env.example
#
# 复制为 .env 并按需修改，不要提交 .env 到 git（含 HF_TOKEN 等敏感信息）：
#   cp docker/vllm/.env.example docker/vllm/.env
# =============================================================================

# ── 必填 ──────────────────────────────────────────────────────────────────────
# HuggingFace 模型 ID 或本地绝对路径
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── HuggingFace Token（私有 / gated 模型需要）────────────────────────────────
HF_TOKEN=

# ── 主机端口映射（Windows/WSL 访问 http://localhost:VLLM_HOST_PORT/v1）──────
VLLM_HOST_PORT=8000

# ── GPU / 并行 ────────────────────────────────────────────────────────────────
# 单卡
VLLM_TENSOR_PARALLEL=1
VLLM_PIPELINE_PARALLEL=1
VLLM_GPU_MEM_UTIL=0.90

# 多卡示例（4×GPU 张量并行）
# VLLM_TENSOR_PARALLEL=4
# CUDA_VISIBLE_DEVICES=0,1,2,3

# ── 精度 & 量化 ────────────────────────────────────────────────────────────────
VLLM_DTYPE=auto
# 量化（可选）: awq | gptq | fp8 | squeezellm
VLLM_QUANTIZATION=

# ── 上下文长度（留空 = 使用模型默认值）──────────────────────────────────────
VLLM_MAX_MODEL_LEN=

# ── 其他 ──────────────────────────────────────────────────────────────────────
VLLM_ENFORCE_EAGER=false
VLLM_ENABLE_LORA=false
VLLM_MAX_LORA_RANK=16

# ── 本地离线模型目录（可选）──────────────────────────────────────────────────
# LOCAL_MODEL_DIR=/path/to/models
