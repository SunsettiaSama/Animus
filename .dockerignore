# =============================================================================
# .dockerignore — 排除不需要进入构建上下文的文件
#
# 构建上下文是项目根目录（docker-compose.yml context: ..）
# 这里的路径均相对于项目根目录
# =============================================================================

# ── Git ───────────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Python 字节码 & 包构建产物 ────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── 虚拟环境 ──────────────────────────────────────────────────────────────────
venv/
.venv/
env/

# ── 本地模型目录（体积庞大，通过 volume 挂载）────────────────────────────────
models/

# ── 运行时数据（体积可能很大，通过 volume 挂载）──────────────────────────────
.react/

# ── 测试代码（不需要进入生产镜像）───────────────────────────────────────────
src/test/

# ── IDE & 编辑器 ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS 生成文件 ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Docker 自身（不需要打入镜像）────────────────────────────────────────────
docker/

# ── 文档 ──────────────────────────────────────────────────────────────────────
docs/
*.md
LICENSE

# ── 启动脚本（Windows 专用，容器不需要）──────────────────────────────────────
start.bat

# ── Agent transcript（可能很大）──────────────────────────────────────────────
agent-transcripts/
